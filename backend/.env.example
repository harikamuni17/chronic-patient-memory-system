# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="Chronic Patient Memory System"
APP_ENV="development"                  # development | production
DEBUG=True

# ── Security ───────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="REPLACE_WITH_A_STRONG_RANDOM_SECRET_KEY"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default – no setup needed)
DATABASE_URL="sqlite:///./chronic_patients.db"

# PostgreSQL (uncomment when migrating to production)
# DATABASE_URL="postgresql://user:password@localhost:5432/chronic_patients_db"

# ── Gemini AI ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY="REPLACE_WITH_YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-1.5-flash"

# ── File Uploads ───────────────────────────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB=20

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_DB_PATH="chroma_db"

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ── Backend API ────────────────────────────────────────────────────────────────
# Base URL for the FastAPI backend
# During development, Vite proxies /api → localhost:8000 (no CORS issues)
# For production on Vercel, set this to your Render backend URL
VITE_API_BASE_URL=http://localhost:8000

# ── App Metadata ───────────────────────────────────────────────────────────────
VITE_APP_NAME="Chronic Patient Memory System"
